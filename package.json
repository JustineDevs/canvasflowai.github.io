{
  "name": "canvasflowai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm exec tsc --noEmit && pnpm exec eslint . && pnpm exec vitest run --reporter=verbose --pool=forks --poolOptions.forks.singleFork && pnpm build",
    "prepare": "lefthook install || true",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "worker:dev": "npx wrangler dev --config workers/cloud-bridge/wrangler.toml",
    "worker:deploy": "npx wrangler deploy --config workers/cloud-bridge/wrangler.toml"
  },
  "dependencies": {
    "konva": "^9.3.20",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.0.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@changesets/cli": "^2.29.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "jsdom": "^26.1.0",
    "lefthook": "^1.12.4",
    "postcss": "^8.5.3",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
